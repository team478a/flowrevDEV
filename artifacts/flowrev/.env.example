# ============================================================
# FlowRev 環境変数サンプル
# 実際の値は .env.local（Replit/Dev）や Vercel の環境変数に設定する。
# AIキー(Anthropic/OpenAI)・Resend は DB（管理画面）で設定するため
# ここには含めない。
# ============================================================

# Supabase（Dev プロジェクト：Replit / Vercel Preview 用）
NEXT_PUBLIC_SUPABASE_URL=https://xxxx-dev.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# アプリURL（招待リンク生成などに使用）
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DB保存するAPIキーの暗号化/復号に使用（32バイト以上の安全なランダム文字列）
ENCRYPTION_KEY=

# Cloudflare Stream Webhook シークレット
# Cloudflare Dashboard → Stream → Webhooks で発行された署名シークレット
# 未設定の場合は署名検証をスキップ（開発時のみ許容）
CLOUDFLARE_STREAM_WEBHOOK_SECRET=
